{
  "installCommand": "npm ci --prefix wakeelfrontend/wakeelfrontend",
  "buildCommand": "npm run build --prefix wakeelfrontend/wakeelfrontend",
  "outputDirectory": "wakeelfrontend/wakeelfrontend/build",
  "redirects": [
    {
      "source": "/",
      "destination": "/wakeel/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/wakeel/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/wakeel/logo192.png",
      "destination": "/logo192.png"
    },
    {
      "source": "/wakeel/logo512.png",
      "destination": "/logo512.png"
    },
    {
      "source": "/wakeel/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/wakeel/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/wakeel/wakeel.mobileconfig",
      "destination": "/wakeel.mobileconfig"
    },
    {
      "source": "/wakeel/RozEmp.mobileconfig",
      "destination": "/RozEmp.mobileconfig"
    },
    {
      "source": "/wakeel/appase.apk",
      "destination": "/appase.apk"
    },
    {
      "source": "/wakeel/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/wakeel",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).mobileconfig",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/x-apple-aspen-config"
        }
      ]
    },
    {
      "source": "/(.*).apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"RozEmp.apk\""
        }
      ]
    }
  ]
}
